parameters:
    level: 8
    paths:
        - src
        - tests
    excludePaths:
        - vendor

    bootstrapFiles:
        - vendor/autoload.php
    scanDirectories:
        - vendor/hyperf
    scanFiles: []
    stubFiles: []
    universalObjectCratesClasses:
        - Hyperf\Contract\ConfigInterface
        - Hyperf\Contract\ContainerInterface
