{
    "name": "zotenme/hyperf-ajax",
    "description": "Larajax-compatible HTML-over-the-wire AJAX helpers for Hyperf.",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "hyperf",
        "ajax",
        "view"
    ],
    "require": {
        "php": "^8.3",
        "hyperf/context": "^3.2",
        "hyperf/contract": "^3.2",
        "hyperf/http-message": "^3.2",
        "hyperf/http-server": "^3.2",
        "psr/container": "^1.1 || ^2.0",
        "psr/http-message": "^1.0 || ^2.0",
        "psr/log": "^1.1 || ^2.0 || ^3.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "mockery/mockery": "^1.6",
        "phpstan/phpstan": "^1.0",
        "phpunit/phpunit": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "Zotenme\\HyperfAjax\\": "src/"
        }
    },
    "scripts": {
        "test": "php tests/smoke.php",
        "analyse": "phpstan analyse --memory-limit=1024M",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix --diff"
    },
    "extra": {
        "hyperf": {
            "config": "Zotenme\\HyperfAjax\\ConfigProvider"
        }
    },
    "suggest": {
        "hyperf/validation": "Required to map Hyperf validation exceptions automatically."
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
